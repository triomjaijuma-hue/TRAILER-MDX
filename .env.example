# TRAILER-MDX Bot Configuration
# Copy to .env and fill in your values

# Bot owner WhatsApp number (with country code, no +)
OWNER_NUMBER=256706106326

# Bot's own number (used for pairing UI hint)
BOT_NUMBER=256706106326

# Bot display name
BOT_NAME=TRAILER-MDX

# Web server port (Railway sets this automatically)
PORT=3000

# ============================================================
# AI keys for .gpt, .llama, .sora, .aion etc.
# Priority: GEMINI > GROQ > OPENROUTER > OPENAI (first one set wins,
# the others act as automatic fallbacks if the first is rate-limited).
# ============================================================
#
# Recommended (100% FREE, no credit card):
#   - Google Gemini:  https://aistudio.google.com/app/apikey
#     ~1 million tokens/day free, supports text + vision.
# GEMINI_API_KEY=
#
#   - Groq (fastest free Llama / Mixtral):  https://console.groq.com/keys
# GROQ_API_KEY=
#
# Optional fallbacks (paid or limited free):
# OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...

# Session basic auth for the pairing webpage (optional but recommended)
# WEB_USERNAME=admin
# WEB_PASSWORD=changeme

# Bot mode: public (anyone) or private (owner only)
MODE=public
