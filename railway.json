{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node src/index.js",
    "restartPolicyType": "ALWAYS",
    "restartPolicyMaxRetries": 100,
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 300
  }
}